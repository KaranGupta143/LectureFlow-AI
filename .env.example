# Supabase
SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key"
SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# AI Provider: openai | gemini | gateway
LECTUREFLOW_AI_PROVIDER="openai"

# OpenAI (used when LECTUREFLOW_AI_PROVIDER=openai)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL=""

# Gemini (used when LECTUREFLOW_AI_PROVIDER=gemini)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_BASE_URL=""

# Custom gateway (used when LECTUREFLOW_AI_PROVIDER=gateway)
LECTUREFLOW_AI_GATEWAY_URL=""
LECTUREFLOW_AI_API_KEY=""
LECTUREFLOW_AI_MODEL="google/gemini-2.5-flash"

# If true, local fallback responses are returned when provider call fails.
# Recommended: false for production and debugging provider issues.
LECTUREFLOW_ALLOW_LOCAL_FALLBACK="false"
